{
  "name": "OmniLSS R/Python Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteEnv": {
    "VIRTUAL_ENV": "/opt/omnilss-venv",
    "PATH": "/opt/omnilss-venv/bin:${containerEnv:PATH}",
    "OMNILSS_WHEELHOUSE": "/opt/omnilss-wheelhouse",
    "JAX_PLATFORMS": "cpu",
    "JAX_ENABLE_X64": "true",
    "RENV_PATHS_CACHE": "/opt/renv/cache",
    "OMNILSS_REFRESH_R_REFERENCE": "0"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "reditorsupport.r-lsp",
        "ms-python.python",
        "ms-python.black-formatter",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/omnilss-venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "omnilss/tests"
        ],
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "bash .codex/setup.sh",
  "postStartCommand": "python --version && R --version | head -1"
}
