{
  "name": "OmniLSS R/Python GPU Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--gpus",
    "all"
  ],
  "remoteEnv": {
    "VIRTUAL_ENV": "/opt/omnilss-venv",
    "PATH": "/opt/omnilss-venv/bin:${containerEnv:PATH}",
    "OMNILSS_WHEELHOUSE": "/opt/omnilss-wheelhouse",
    "JAX_PLATFORMS": "cuda",
    "JAX_ENABLE_X64": "true",
    "RENV_PATHS_CACHE": "/opt/renv/cache",
    "OMNILSS_REFRESH_R_REFERENCE": "0"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "reditorsupport.r-lsp",
        "ms-python.python",
        "ms-python.black-formatter",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/omnilss-venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "omnilss/tests/test_device_gpu.py"
        ],
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "JAX_PLATFORMS=cpu bash .codex/setup.sh && python -m pip install --upgrade 'jax[cuda12]' && JAX_PLATFORMS=cuda python -m pytest omnilss/tests/test_device_gpu.py -q -rs",
  "postStartCommand": "python - <<'PY'\nimport jax\nprint('JAX backend:', jax.default_backend())\nprint('JAX devices:', jax.devices())\nPY"
}
